<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tecnorepara.controller.FacturaController"
            prefWidth="1100"
            prefHeight="700">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="cabecera-modulo">
            <Label text="Facturación"
                   styleClass="titulo-modulo"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Buscar:"/>

            <TextField fx:id="txtBuscar"
                       prefWidth="360"
                       promptText="Cliente, método, estado o fecha"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18" styleClass="contenido-modulo">

            <VBox spacing="15" styleClass="card-modulo">

                <GridPane hgap="15" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Orden para facturar" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbOrden"
                              promptText="Seleccione orden para facturar"
                              GridPane.rowIndex="1"
                              GridPane.columnIndex="0"
                              GridPane.columnSpan="2"
                              maxWidth="Infinity"
                              onAction="#cargarDatosOrden"/>

                    <Label text="Cliente" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtCliente"
                               promptText="Cliente"
                               editable="false"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="0"/>

                    <Label text="Total" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <TextField fx:id="txtTotal"
                               promptText="Total"
                               editable="false"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="1"/>

                    <Label text="Método de Pago" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbMetodoPago"
                              promptText="Método de pago"
                              GridPane.rowIndex="5"
                              GridPane.columnIndex="0"
                              maxWidth="Infinity"/>

                    <Label text="Estado" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    <ComboBox fx:id="cmbEstado"
                              promptText="Estado"
                              GridPane.rowIndex="5"
                              GridPane.columnIndex="1"
                              maxWidth="Infinity"/>
                </GridPane>

                <HBox spacing="10">
                    <Button text="Facturar"
                            onAction="#facturar"
                            styleClass="boton-guardar"/>

                    <Button text="PDF Factura"
                            onAction="#generarPdf"
                            styleClass="boton-pdf"/>

                    <Button text="Eliminar"
                            onAction="#eliminar"
                            styleClass="boton-eliminar"/>

                    <Button text="Limpiar"
                            onAction="#limpiar"
                            styleClass="boton-limpiar"/>

                    <Button text="Exportar Excel"
                            onAction="#exportarExcel"
                            styleClass="boton-excel"/>
                </HBox>

            </VBox>

            <VBox spacing="10" styleClass="card-modulo">

                <Label text="Listado de facturas"
                       style="-fx-font-size:18px; -fx-font-weight:bold;"/>

                <TableView fx:id="tablaFacturas"
                           prefHeight="320">

                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colIdOrden" text="Orden" prefWidth="80"/>
                        <TableColumn fx:id="colCliente" text="Cliente" prefWidth="230"/>
                        <TableColumn fx:id="colMetodoPago" text="Pago" prefWidth="140"/>
                        <TableColumn fx:id="colTotal" text="Total" prefWidth="120"/>
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="120"/>
                        <TableColumn fx:id="colFecha" text="Fecha" prefWidth="200"/>
                    </columns>

                </TableView>

            </VBox>

        </VBox>
    </center>

</BorderPane>
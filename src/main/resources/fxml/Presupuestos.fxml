<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tecnorepara.controller.PresupuestoController"
            prefWidth="1100"
            prefHeight="700">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding:20;">
            <Label text="Gestión de Presupuestos"
                   styleClass="titulo-modulo"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Buscar:"/>
            <TextField fx:id="txtBuscar"
                       prefWidth="360"
                       promptText="Orden, estado o fecha"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18" styleClass="cabecera-modulo">

            <VBox spacing="15" styleClass="card-modulo">

                <GridPane hgap="15" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Orden" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbOrden"
                              promptText="Seleccione orden"
                              GridPane.rowIndex="1"
                              GridPane.columnIndex="0"
                              GridPane.columnSpan="2"
                              maxWidth="Infinity"/>

                    <Label text="Mano de Obra" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtManoObra"
                               promptText="Mano de Obra"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="0"/>

                    <Label text="Total Repuestos" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <TextField fx:id="txtTotalRepuestos"
                               promptText="Total Repuestos"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="1"/>

                    <Label text="Estado" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbEstado"
                              promptText="Estado"
                              GridPane.rowIndex="5"
                              GridPane.columnIndex="0"
                              maxWidth="Infinity"/>

                    <VBox spacing="8"
                          GridPane.rowIndex="4"
                          GridPane.columnIndex="1"
                          GridPane.rowSpan="2"
                          style="-fx-background-color:#F0FDF4;
                                 -fx-border-color:#BBF7D0;
                                 -fx-border-radius:10;
                                 -fx-background-radius:10;
                                 -fx-padding:12;">

                        <Label text="TOTAL PRESUPUESTO"
                               style="-fx-font-size:12px;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#166534;"/>

                        <TextField fx:id="txtTotal"
                                   promptText="0"
                                   editable="false"
                                   prefHeight="38"
                                   style="-fx-font-size:18px;
                                          -fx-font-weight:bold;
                                          -fx-text-fill:#166534;
                                          -fx-background-color:white;
                                          -fx-background-radius:8;"/>
                    </VBox>
                </GridPane>

                <HBox spacing="10">
                    <Button text="Guardar"
                            onAction="#guardar"
                            styleClass="boton-guardar"/>

                    <Button text="Modificar"
                            onAction="#modificar"
                            styleClass="boton-modificar"/>

                    <Button text="Eliminar"
                            onAction="#eliminar"
                            styleClass="boton-eliminar"/>

                    <Button text="Limpiar"
                            onAction="#limpiar"
                            styleClass="boton-limpiar"/>

                    <Button text="Exportar Excel"
                            onAction="#exportarExcel"
                            styleClass="boton-excel"/>

                    <Button text="PDF"
                            onAction="#generarPdf"
                            styleClass="boton-pdf"/>
                </HBox>

            </VBox>

            <VBox spacing="10" styleClass="card-modulo">

                <Label text="Listado de presupuestos"
                       style="-fx-font-size:18px; -fx-font-weight:bold;"/>

                <TableView fx:id="tablaPresupuestos"
                           prefHeight="300">

                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colDescripcionOrden" text="Orden" prefWidth="320"/>
                        <TableColumn fx:id="colManoObra" text="Mano Obra" prefWidth="120"/>
                        <TableColumn fx:id="colTotalRepuestos" text="Repuestos" prefWidth="120"/>
                        <TableColumn fx:id="colTotal" text="Total" prefWidth="120"/>
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="140"/>
                        <TableColumn fx:id="colFechaPresupuesto" text="Fecha" prefWidth="180"/>
                    </columns>

                </TableView>

            </VBox>

        </VBox>
    </center>

</BorderPane>
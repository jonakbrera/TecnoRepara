<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tecnorepara.controller.ProductoController"
            prefWidth="1100"
            prefHeight="700">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding:20;">
            <Label text="Gestión de Productos"
                   styleClass="titulo-modulo"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Buscar:"/>

            <TextField fx:id="txtBuscar"
                       prefWidth="340"
                       promptText="Código, descripción o categoría"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18" styleClass="cabecera-modulo">

            <VBox spacing="15" styleClass="card-modulo">

                <GridPane hgap="15" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Código" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtCodigo"
                               promptText="Código del producto"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="0"/>

                    <Label text="Categoría" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <TextField fx:id="txtCategoria"
                               promptText="Categoría"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"/>

                    <Label text="Descripción" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtDescripcion"
                               promptText="Descripción del producto"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="0"
                               GridPane.columnSpan="2"/>

                    <Label text="Precio Compra" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtPrecioCompra"
                               promptText="Precio de compra"
                               GridPane.rowIndex="5"
                               GridPane.columnIndex="0"/>

                    <Label text="Precio Venta" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    <TextField fx:id="txtPrecioVenta"
                               promptText="Precio de venta"
                               GridPane.rowIndex="5"
                               GridPane.columnIndex="1"/>

                    <Label text="Stock Actual" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtStockActual"
                               promptText="Stock actual"
                               GridPane.rowIndex="7"
                               GridPane.columnIndex="0"/>

                    <Label text="ID Proveedor" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                    <TextField fx:id="txtIdProveedor"
                               promptText="ID del proveedor"
                               GridPane.rowIndex="7"
                               GridPane.columnIndex="1"/>

                    <Label text="Stock Mínimo" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtStockMinimo"
                               promptText="Stock mínimo"
                               GridPane.rowIndex="9"
                               GridPane.columnIndex="0"/>

                    <Label text="Stock Máximo" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
                    <TextField fx:id="txtStockMaximo"
                               promptText="Stock máximo"
                               GridPane.rowIndex="9"
                               GridPane.columnIndex="1"/>
                </GridPane>

                <HBox spacing="10">
                    <Button text="Guardar"
                            onAction="#guardar"
                            styleClass="boton-guardar"/>

                    <Button text="Modificar"
                            onAction="#modificar"
                            styleClass="boton-modificar"/>

                    <Button text="Eliminar"
                            onAction="#eliminar"
                            styleClass="boton-eliminar"/>

                    <Button text="Limpiar"
                            onAction="#limpiar"
                            styleClass="boton-limpiar"/>

                    <Button text="Exportar Excel"
                            onAction="#exportarExcel"
                            styleClass="boton-excel"/>
                </HBox>

            </VBox>

            <VBox spacing="10" styleClass="card-modulo">

                <Label text="Listado de productos"
                       style="-fx-font-size:18px; -fx-font-weight:bold;"/>

                <TableView fx:id="tablaProductos"
                           prefHeight="300">

                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="55"/>
                        <TableColumn fx:id="colCodigo" text="Código" prefWidth="90"/>
                        <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="230"/>
                        <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120"/>
                        <TableColumn fx:id="colPrecioCompra" text="Compra" prefWidth="90"/>
                        <TableColumn fx:id="colPrecioVenta" text="Venta" prefWidth="90"/>
                        <TableColumn fx:id="colStockActual" text="Stock" prefWidth="70"/>
                        <TableColumn fx:id="colStockMinimo" text="Mín." prefWidth="60"/>
                        <TableColumn fx:id="colStockMaximo" text="Máx." prefWidth="60"/>
                        <TableColumn fx:id="colIdProveedor" text="Proveedor" prefWidth="90"/>
                    </columns>

                </TableView>

            </VBox>

        </VBox>
    </center>

</BorderPane>
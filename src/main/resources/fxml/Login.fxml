<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tecnorepara.controller.LoginController"
            stylesheets="@/css/estilos.css"
            prefWidth="900"
            prefHeight="560"
            style="-fx-background-color:#F4F6F8;">

    <center>
        <HBox alignment="CENTER" spacing="0">

            <VBox alignment="CENTER" spacing="18"
                  prefWidth="420"
                  styleClass="cabecera-modulo">

                <ImageView fitWidth="230" preserveRatio="true">
                    <image>
                        <Image url="@/imagenes/logo.png"/>
                    </image>
                </ImageView>

                <Label text="Sistema Integral de Gestión"
                       style="-fx-text-fill:white; -fx-font-size:18px; -fx-font-weight:bold;"/>

                <Label text="Gestión completa para taller técnico"
                       style="-fx-text-fill:#CBD5E1; -fx-font-size:13px;"/>

            </VBox>

            <VBox alignment="CENTER" spacing="18"
                  prefWidth="480"
                  style="-fx-background-color:white; -fx-padding:50;">

                <Label text="Bienvenido"
                       style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#1E2A38;"/>

                <Label text="Inicia sesión para continuar"
                       style="-fx-font-size:14px; -fx-text-fill:#64748B;"/>

                <VBox spacing="8" prefWidth="320">
                    <Label text="Usuario"/>
                    <TextField fx:id="txtUsuario"
                               promptText="Ingrese su usuario"
                               prefHeight="42"/>
                </VBox>

                <VBox spacing="8" prefWidth="320">
                    <Label text="Contraseña"/>
                    <PasswordField fx:id="txtPassword"
                                   promptText="Ingrese su contraseña"
                                   prefHeight="42"/>
                </VBox>

                <Button text="Ingresar"
                        onAction="#ingresar"
                        prefWidth="320"
                        prefHeight="44"
                        style="-fx-background-color:#2563EB;
                               -fx-text-fill:white;
                               -fx-font-size:15px;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

                <Label text="© 2026 TecnoRepara - Versión 1.0"
                       style="-fx-font-size:11px; -fx-text-fill:#94A3B8;"/>

            </VBox>

        </HBox>
    </center>

</BorderPane>